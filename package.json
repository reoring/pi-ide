{
	"name": "pi-ide",
	"version": "0.1.0",
	"description": "IDE-style code intelligence for Pi: structural analysis, symbol search, impact checks, and safer workspace scanning",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"pi-ide-mcp": "dist/mcp/entry.js",
		"pi-shazam-mcp": "dist/mcp/entry.js"
	},
	"files": [
		"dist/**/*"
	],
	"scripts": {
		"prebuild": "rm -rf dist",
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"dev": "tsc --watch",
		"prepublishOnly": "npm run build",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"pi-package",
		"pi-coding-agent",
		"extension",
		"codebase-analysis",
		"tree-sitter",
		"lsp",
		"pagerank"
	],
	"pi": {
		"extensions": [
			"./dist"
		]
	},
	"author": "gjczone; pi-ide fork by reoring",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/reoring/pi-ide.git"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"iconv-lite": "^0.7.2",
		"tree-sitter": "^0.22.4",
		"tree-sitter-c": "0.23.4",
		"tree-sitter-c-sharp": "0.23.1",
		"tree-sitter-cpp": "0.23.4",
		"tree-sitter-css": "0.23.1",
		"tree-sitter-go": "0.23.4",
		"tree-sitter-html": "0.23.2",
		"tree-sitter-java": "0.23.5",
		"tree-sitter-javascript": "0.23.1",
		"tree-sitter-json": "0.24.8",
		"tree-sitter-python": "0.23.6",
		"tree-sitter-ruby": "0.23.1",
		"tree-sitter-rust": "0.23.2",
		"tree-sitter-typescript": "0.23.2",
		"typebox": "*",
		"vscode-jsonrpc": "^9.0.0",
		"vscode-languageserver-protocol": "^3.18.0",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"typebox": "*"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"overrides": {
		"tree-sitter": "^0.22.4"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
